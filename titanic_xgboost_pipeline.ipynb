  {
   "cell_type": "markdown",
   "id": "9dfd507c",
   "metadata": {},
   "source": [
    "## 3. Data Processing & Feature Engineering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "dd52057f",
   "metadata": {},
   "outputs": [],
   "source": [
    "def process_data(df):\n",
    "    \"\"\"\n",
    "    Cleans raw data and engineers new features for prediction.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    df : pd.DataFrame\n",
    "        Raw Titanic dataset\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    df : pd.DataFrame\n",
    "        Cleaned and feature-engineered dataset\n",
    "    \"\"\"\n",
    "    df = df.copy()\n",
    "    \n",
    "    # 1. Drop columns with excessive missing data\n",
    "    df = df.drop('Cabin', axis=1)\n",
    "    \n",
    "    # 2. Impute missing numerical values with the median\n",
    "    df['Age'] = df['Age'].fillna(df['Age'].median())\n",
    "    df['Fare'] = df['Fare'].fillna(df['Fare'].median())\n",
    "    \n",
    "    # 3. Impute missing categorical values with the mode\n",
    "    if df['Embarked'].isnull().any():\n",
    "        df['Embarked'] = df['Embarked'].fillna(df['Embarked'].mode()[0])\n",
    "    \n",
    "    # 4. Feature Engineering: Create family size and solo-traveller flags\n",
    "    df['FamilySize'] = df['SibSp'] + df['Parch'] + 1\n",
    "    df['IsAlone'] = (df['FamilySize'] == 1).astype(int)\n",
    "    \n",
    "    # 5. Feature Engineering: Extract standard titles from raw name strings\n",
    "    def extract_title(name):\n",
    "        if pd.isna(name):\n",
    "            return 'Unknown'\n",
    "        title = name.split(',')[1].split('.')[0].strip()\n",
    "        return title\n",
    "    \n",
    "    df['Title'] = df['Name'].apply(extract_title)\n",
    "    \n",
    "    # 6. Map rare titles to 'Rare' category\n",
    "    title_map = {\n",
    "        'Mlle': 'Miss', \n",
    "        'Ms': 'Miss', \n",
    "        'Mme': 'Mrs', \n",
    "        'Lady': 'Rare', \n",
    "        'Countess': 'Rare',\n",
    "        'Capt': 'Rare', \n",
    "        'Col': 'Rare', \n",
    "        'Don': 'Rare', \n",
    "        'Dr': 'Rare', \n",
    "        'Major': 'Rare',\n",
    "        'Rev': 'Rare', \n",
    "        'Sir': 'Rare', \n",
    "        'Jonkheer': 'Rare', \n",
    "        'Dona': 'Rare'\n",
    "    }\n",
    "    df['Title'] = df['Title'].replace(title_map)\n",
    "    \n",
    "    # 7. Drop unique text identifiers that add noise to the model\n",
    "    df = df.drop(['PassengerId', 'Name', 'Ticket'], axis=1)\n",
    "    \n",
    "    return df\n",
    "\n",
    "# Apply the processing pipeline to both datasets uniformly\n",
    "print(\"Processing training data...\")\n",
    "train_clean = process_data(train_df)\n",
    "print(f\"Cleaned training data shape: {train_clean.shape}\")\n",
    "\n",
    "print(\"\\nProcessing test data...\")\n",
    "test_clean = process_data(test_df)\n",
    "print(f\"Cleaned test data shape: {test_clean.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "17f94fe9",
   "metadata": {},
   "source": [
    "## 4. Categorical Encoding"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1a262ae8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Convert text categories into binary indicators\n",
    "train_encoded = pd.get_dummies(\n",
    "    train_clean, \n",
    "    columns=['Sex', 'Embarked', 'Title'], \n",
    "    drop_first=True, \n",
    "    dtype=int\n",
    ")\n",
    "\n",
    "test_encoded = pd.get_dummies(\n",
    "    test_clean, \n",
    "    columns=['Sex', 'Embarked', 'Title'], \n",
    "    drop_first=True, \n",
    "    dtype=int\n",
    ")\n",
    "\n",
    "# Align the test set to guarantee it has the exact same columns as the training set\n",
    "test_encoded = test_encoded.reindex(\n",
    "    columns=train_encoded.drop(columns=['Survived']).columns, \n",
    "    fill_value=0\n",
    ")\n",
    "\n",
    "print(f\"Training set shape after encoding: {train_encoded.shape}\")\n",
    "print(f\"Test set shape after encoding: {test_encoded.shape}\")\n",
    "print(f\"\\nNumber of features: {train_encoded.shape[1] - 1}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "179bd6f6",
   "metadata": {},
   "source": [
    "## 5. Model Training & Hyperparameter Tuning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "29a61fed",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Separate target variable and features\n",
    "y = train_encoded['Survived']\n",
    "X = train_encoded.drop('Survived', axis=1)\n",
    "\n",
    "print(f\"Features shape: {X.shape}\")\n",
    "print(f\"Target shape: {y.shape}\")\n",
    "print(f\"\\nTarget distribution:\")\n",
    "print(y.value_counts())\n",
    "\n",
    "# Initialize XGBoost classifier\n",
    "xgb = XGBClassifier(\n",
    "    eval_metric='logloss', \n",
    "    random_state=42,\n",
    "    verbosity=0\n",
    ")\n",
    "\n",
    "# Define the grid of hyperparameters to test\n",
    "param_grid = {\n",
    "    'n_estimators': [100, 200],\n",
    "    'max_depth': [3, 5, 7],\n",
    "    'learning_rate': [0.01, 0.1, 0.2],\n",
    "    'subsample': [0.8, 1.0]\n",
    "}\n",
    "\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"Running Grid Search for XGBClassifier...\")\n",
    "print(\"This may take a few minutes...\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "grid_search = GridSearchCV(\n",
    "    estimator=xgb, \n",
    "    param_grid=param_grid, \n",
    "    cv=5, \n",
    "    scoring='accuracy', \n",
    "    n_jobs=-1,\n",
    "    verbose=1\n",
    ")\n",
    "grid_search.fit(X, y)\n",
    "\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(f\"🏆 Best parameters found:\")\n",
    "for param, value in grid_search.best_params_.items():\n",
    "    print(f\"   {param}: {value}\")\n",
    "print(f\"\\n📈 Best Cross-Validation Accuracy: {grid_search.best_score_:.4f}\")\n",
    "print(\"=\"*60)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ba45d90b",
   "metadata": {},
   "source": [
    "## 6. Model Evaluation on Training Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b88d64e8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Get the best model\n",
    "best_model = grid_search.best_estimator_\n",
    "\n",
    "# Make predictions on training data for evaluation\n",
    "train_predictions = best_model.predict(X)\n",
    "train_accuracy = (train_predictions == y).mean()\n",
    "\n",
    "print(f\"Training Accuracy: {train_accuracy:.4f}\")\n",
    "print(f\"\\nClassification Report (Training Set):\")\n",
    "print(classification_report(y, train_predictions, target_names=['Did Not Survive', 'Survived']))\n",
    "\n",
    "print(f\"\\nConfusion Matrix (Training Set):\")\n",
    "cm = confusion_matrix(y, train_predictions)\n",
    "print(cm)"
   ]
  },
